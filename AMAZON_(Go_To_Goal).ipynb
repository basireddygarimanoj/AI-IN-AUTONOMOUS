        "# AMAZON – Go-To-Goal\n",
        "\n",
        "import math\n",
        "\n",
        "x1, y1 = 0, 0\n",
        "x2, y2 = 6, 8\n",
        "\n",
        "distance = math.sqrt((x2-x1)**2 + (y2-y1)**2)\n",
        "\n",
        "print(\"Output: Distance =\", int(distance), \"m\")"
      ]
    }
  ]
