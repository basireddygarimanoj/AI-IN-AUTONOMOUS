        "# SESSION 4 – APPLE (Motor Control)\n",
        "\n",
        "# Step 1: Define distance and time\n",
        "distance = 5      # meters\n",
        "time = 2          # seconds\n",
        "\n",
        "# Step 2: Calculate speed\n",
        "speed = distance / time\n",
        "\n",
        "# Step 3: Output result\n",
        "print(\"Output:\", speed, \"m/s\")\n",
        "print(\"Industry: Apple Robotics\")"
      ]
    }
