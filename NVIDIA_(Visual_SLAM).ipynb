      "source": [
        "# NVIDIA – Visual SLAM\n",
        "\n",
        "# Previous pose (x, y)\n",
        "prev_pose = (2.0, 3.0)\n",
        "\n",
        "# Motion detected (dx, dy)\n",
        "motion = (0.4, 0.6)\n",
        "\n",
        "# Calculate new pose\n",
        "new_pose = (prev_pose[0] + motion[0], prev_pose[1] + motion[1])\n",
        "\n",
        "# Output\n",
        "print(\"Output:\", new_pose)"
      ]
    }
  ]
}