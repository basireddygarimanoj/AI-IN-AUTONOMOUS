      "source": [
        "# AMAZON – Path Planning\n",
        "\n",
        "# Path costs\n",
        "path_A = 10\n",
        "path_B = 5\n",
        "path_C = 8\n",
        "\n",
        "# Find minimum cost path\n",
        "if path_B < path_A and path_B < path_C:\n",
        "    result = \"Path B\"\n",
        "elif path_A < path_C:\n",
        "    result = \"Path A\"\n",
        "else:\n",
        "    result = \"Path C\"\n",
        "\n",
        "# Output\n",
        "print(\"Output:\", result)"
      ]
    }
