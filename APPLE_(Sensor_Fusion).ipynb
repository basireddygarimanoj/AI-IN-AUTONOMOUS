      "source": [
        "# APPLE – Sensor Fusion\n",
        "\n",
        "# Sensor values (in degrees)\n",
        "imu = 20\n",
        "vision = 40\n",
        "\n",
        "# Fuse sensors\n",
        "fused = (imu + vision) / 2\n",
        "\n",
        "# Output\n",
        "print(\"Output:\", int(fused), \"°\")\n",
        "print(\"Industry: iOS Robotics\")"
      ]
    }
  ]
