      "source": [
        "# TESLA – Edge Detection\n",
        "\n",
        "import math\n",
        "\n",
        "# Gradient values\n",
        "Gx = 5\n",
        "Gy = 12\n",
        "\n",
        "# Compute edge magnitude\n",
        "edge = math.sqrt(Gx**2 + Gy**2)\n",
        "\n",
        "# Output\n",
        "print(\"Output:\", int(edge))\n",
        "print(\"Industry: Autonomous Driving\")"
      ]
    }
  ]
