      "source": [
        "# META – Camera Projection\n",
        "\n",
        "# Step 1: Define values\n",
        "f = 600     # focal length\n",
        "X = 1       # object coordinate\n",
        "Z = 2       # depth\n",
        "\n",
        "# Step 2: Apply projection formula\n",
        "u = f * X / Z\n",
        "\n",
        "# Step 3: Output result\n",
        "print(\"Output:\", u, \"px\")\n",
        "print(\"Industry: AR/VR Systems\")"
      ]
    }
  ]
